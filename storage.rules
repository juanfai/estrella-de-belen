rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de perfil: cada usuario puede leer y escribir solo la suya
    match /profile_photos/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && fileName == request.auth.uid + '.jpg';
    }

    // Audio e imágenes de meditaciones: lectura autenticada, escritura solo admin
    match /{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
