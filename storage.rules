rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Audio e imágenes de meditaciones ──────────────────────────────────────
    // Cualquier usuario autenticado puede descargar; nadie puede subir desde el cliente
    match /{allPaths=**} {
      allow read:  if request.auth != null;
      // Solo usuarios con custom claim admin:true pueden subir archivos
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
