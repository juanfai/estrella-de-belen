rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Perfil de usuario ──────────────────────────────────────────────────────
    match /users/{uid} {

      // Solo el propio usuario puede leer su perfil
      allow read: if request.auth != null && request.auth.uid == uid;

      // Creación al registrarse: solo puede crear su propio documento
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.displayName is string
        && request.resource.data.email is string;

      // Actualización: solo campos que la app escribe legítimamente
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'favorites',
             'totalSessions', 'totalMinutes', 'streak', 'lastSessionDate',
             'notificationsEnabled', 'notificationTime'
           ]);

      // Nadie puede borrar perfiles desde el cliente
      allow delete: if false;
    }

    // ── Meditaciones ──────────────────────────────────────────────────────────
    match /meditations/{id} {
      // Cualquier usuario autenticado puede leer
      allow read: if request.auth != null;
      // Solo usuarios con custom claim admin:true pueden escribir
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Denegar todo lo demás ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
